---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { href } from '../../i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'fr');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^fr\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const slug = post.id.replace(/^fr\//, '');
const alternates = {
  fr: `/blog/${slug}`,
  ...(post.data.translationOf ? { en: `/en/blog/${post.data.translationOf}` } : {}),
};

const formatter = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  lang="fr"
  title={`${post.data.title} — Sereno`}
  description={post.data.description}
  alternates={alternates}
>
  <article class="section">
    <div class="wrap prose">
      <p class="back"><a href={href('fr', 'blog')}>← Blog</a></p>
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={post.data.pubDate.toISOString()}>
          Publié le {formatter.format(post.data.pubDate)}
        </time>
      </p>
      <Content />
    </div>
  </article>
</Base>

<style>
  .back {
    margin-bottom: 24px;
  }

  .back a {
    text-decoration: none;
    font-size: 14.5px;
    font-weight: 600;
  }

  .meta {
    color: var(--ink-faint);
    font-size: 14px;
    margin: 8px 0 32px;
  }
</style>
