---
import Base from '../layouts/Base.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { href } from '../i18n/ui';

const faqs = [
  {
    q: 'Sereno se connecte-t-il à ma banque ?',
    a: 'Non, et c’est un choix : tu notes tes dépenses toi-même. Ce geste de cinq secondes est le cœur de la méthode. Conséquence : aucun identifiant bancaire à confier.',
  },
  {
    q: 'Ai-je besoin d’un compte ?',
    a: 'Non. L’app fonctionne entièrement sans compte : données en local sur ton appareil. Le compte (gratuit) ne sert qu’à synchroniser plusieurs appareils et débloquer comptes multiples, catégories perso et récurrences côté serveur.',
  },
  {
    q: 'Y a-t-il une limite en mode invité ?',
    a: 'Non. Pas de quota de transactions, pas de plafond artificiel. Le mode invité est complet et gratuit pour toujours.',
  },
  {
    q: 'Sereno utilise-t-il de l’IA ?',
    a: 'Non. Pas de scan de reçus par IA, pas de catégorisation automatique opaque. Tu notes, tu vois — c’est tout.',
  },
  {
    q: 'Où sont stockées mes données ?',
    a: 'Sans compte : IndexedDB sur ton appareil uniquement. Avec un compte : Postgres chez Supabase (UE), cloisonné par utilisateur. Détails dans la politique de confidentialité.',
  },
  {
    q: 'Que se passe-t-il si je crée un compte après des semaines en local ?',
    a: 'Tes données locales migrent automatiquement vers ton compte. Si la migration échoue, tout est annulé et tes données locales restent intactes.',
  },
  {
    q: 'Pourquoi c’est gratuit ? Puis-je soutenir ?',
    a: 'Parce que le mode local ne coûte presque rien à faire tourner, et qu’il n’y a pas de plan payant. Le soutien est volontaire via la page Soutenir (Stripe) — jamais obligatoire, jamais une condition d’accès.',
  },
  {
    q: 'Puis-je récupérer mes données ?',
    a: 'Oui : export CSV et sauvegarde JSON complète depuis les réglages. Tes données t’appartiennent, y compris pour partir.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});
---

<Base
  lang="fr"
  routeKey="faq"
  title="FAQ — Sereno"
  description="Gratuité, mode invité sans limite, compte optionnel, pas d’IA : les réponses directes sur Sereno."
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="lbl">FAQ</span>
        <h1>Questions directes, réponses directes.</h1>
      </div>
      <FaqAccordion items={faqs} />
      <p class="ask">
        Une autre question ? <a href={href('fr', 'contact')}>Écris-nous</a> — un humain répond.
      </p>
    </div>
  </section>
</Base>

<style>
  h1 {
    font-size: clamp(30px, 5vw, 42px);
  }

  .ask {
    margin-top: 36px;
    color: var(--ink-soft);
  }
</style>
