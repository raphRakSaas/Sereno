---
import Base from '../../layouts/Base.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import { APP_URL, t } from '../../i18n/ui';

const tr = t('en');

const blocks = [
  {
    label: 'Entry',
    title: 'Two taps, and it’s logged',
    body: 'Amount, category, done. Templates for what comes back often, transfers treated correctly — neither income nor expense.',
    mediaSrc: '/screenshots/transactions.png',
    mediaAlt: 'Sereno transactions screen',
  },
  {
    label: 'Budgets',
    title: 'Frame spending without punishment',
    body: 'Category or global budgets, honest end-of-period projections. An overrun shows in calm coral: “€50 over — it happens.”',
    mediaSrc: '/screenshots/budgets.png',
    mediaAlt: 'Sereno budgets screen',
    reverse: true,
  },
  {
    label: 'Statistics',
    title: 'See it at a glance',
    body: 'Category breakdown, month comparisons, calendar of spending days. Facts, never judgment.',
    mediaSrc: '/screenshots/stats.png',
    mediaAlt: 'Sereno statistics screen',
  },
  {
    label: 'Guest mode',
    title: 'Full featured, no account',
    body: 'Transactions, budgets, stats, calendar — everything works locally on your device. No quotas, no artificial limits.',
    mediaSrc: '/screenshots/guest.png',
    mediaAlt: 'Sereno guest mode',
    reverse: true,
  },
  {
    label: 'Sync',
    title: 'Optional account, free',
    body: 'When you want to sync devices: multiple accounts, custom categories, server-side recurring rules. Local data migrates without loss.',
    mediaSrc: '/screenshots/dashboard.png',
    mediaAlt: 'Sereno synced dashboard',
  },
];
---

<Base
  lang="en"
  routeKey="features"
  title="Features — Sereno"
  description="Two-tap entry, calm budgets, quiet statistics, offline mode: everything Sereno does, without ever rushing you."
>
  <section class="hero-head section-soft">
    <div class="wrap">
      <div class="section-head">
        <span class="lbl">Features</span>
        <h1>Everything you need to see clearly.</h1>
        <p>
          Sereno deliberately does less: no bank connection, no pushy
          notifications, no AI. What remains is carefully made — and free
          forever.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {
        blocks.map((block) => (
          <FeatureBlock
            label={block.label}
            title={block.title}
            body={block.body}
            mediaSrc={block.mediaSrc}
            mediaAlt={block.mediaAlt}
            reverse={block.reverse}
          />
        ))
      }

      <div class="cta-row">
        <div class="cta-band cta-band-coral">
          <h2>Try it with zero setup.</h2>
          <p>The app opens in guest mode. You log, you see, that’s it.</p>
          <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>{tr('cta.openApp')}</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-head {
    padding: 64px 0 24px;
  }

  h1 {
    font-size: clamp(30px, 5vw, 42px);
  }

  .cta-row {
    margin-top: 40px;
  }
</style>
