---
import Base from '../../layouts/Base.astro';
import PhoneMock from '../../components/PhoneMock.astro';
import { APP_URL, href, t } from '../../i18n/ui';
import { getCollection } from 'astro:content';

const tr = t('en');

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const pillars = [
  {
    title: 'Local first',
    body: 'Your data stays on your device. An account only helps if you want to sync across devices — and it’s free.',
    icon: '/illustrations/local-first.svg',
  },
  {
    title: 'Manual, on purpose',
    body: 'No bank connection. Logging a purchase yourself takes five seconds — and that’s exactly what puts you back in charge.',
    icon: '/illustrations/hero-clarity.svg',
  },
  {
    title: 'Never an alarm',
    body: 'An exceeded budget isn’t a failure. Sereno states it calmly, in coral — and helps you adjust next month.',
    icon: '/illustrations/support-coffee.svg',
  },
];
---

<Base
  lang="en"
  routeKey="home"
  title="Sereno — see your money clearly, without the anxiety"
  description={tr('site.description')}
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="lbl">Personal budgeting · free</span>
        <h1>See your money clearly, without the anxiety.</h1>
        <p>
          You log spending by hand, in two taps. Sereno shows where your money
          goes — calmly, without guilt. Free forever, no account required,
          right on your device.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>
            {tr('cta.openApp')}
          </a>
          <a class="btn btn-ghost" href={href('en', 'method')}>Discover the method</a>
        </div>
        <p class="hero-note">No sign-up · No bank connection · No ads</p>
      </div>
      <div class="hero-visual">
        <img class="hero-illo" src="/illustrations/hero-clarity.svg" alt="" width="200" height="160" />
        <PhoneMock src="/screenshots/dashboard.png" alt="Sereno dashboard" width={250} />
      </div>
    </div>
  </section>

  <section class="section section-surface" aria-label="Sereno’s three principles">
    <div class="wrap pillars">
      {
        pillars.map((pillar) => (
          <article class="pillar">
            <img src={pillar.icon} alt="" width="48" height="48" />
            <h2>{pillar.title}</h2>
            <p>{pillar.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section-dark trust">
    <div class="wrap trust-inner">
      <span class="lbl">Trust</span>
      <h2>Free forever. Your data stays yours.</h2>
      <ul>
        <li>Full guest mode — no quotas, no artificial limits</li>
        <li>Optional account only to sync your devices</li>
        <li>No AI, no receipt scanning, no selling your data</li>
        <li>Voluntary support welcome — never required</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="lbl">Blog</span>
        <h2>Calm guides for your money.</h2>
      </div>
      <ul class="teasers">
        {
          posts.map((post) => (
            <li>
              <a href={`/en/blog/${post.id.replace(/^en\//, '')}`}>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <span>{tr('blog.readMore')} →</span>
              </a>
            </li>
          ))
        }
      </ul>
      <a class="more" href={href('en', 'blog')}>All posts →</a>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <div class="cta-band cta-band-coral">
        <h2>Start now. Literally now.</h2>
        <p>No account to create. The app opens, you log your first expense, you’re in.</p>
        <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>{tr('cta.openApp')}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 72px 0 80px;
    background: var(--paper-soft);
  }

  .hero-grid {
    display: grid;
    gap: 48px;
    align-items: center;
    grid-template-columns: 1fr;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    max-width: 34rem;
  }

  h1 {
    font-size: clamp(34px, 5.4vw, 52px);
  }

  .hero-copy > p {
    color: var(--ink-soft);
    font-size: 18px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-note {
    font-size: 13.5px;
    color: var(--ink-faint);
  }

  .hero-visual {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 16px;
    position: relative;
  }

  .hero-illo {
    display: none;
    width: 140px;
    height: auto;
    opacity: 0.9;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.15fr 0.85fr;
    }

    .hero-illo {
      display: block;
      position: absolute;
      left: 0;
      top: 12%;
    }

    .hero-visual {
      justify-content: flex-end;
      min-height: 420px;
    }
  }

  .pillars {
    display: grid;
    gap: 36px;
    grid-template-columns: 1fr;
  }

  .pillar img {
    margin-bottom: 12px;
  }

  .pillar h2 {
    font-size: 21px;
    margin-bottom: 10px;
  }

  .pillar p {
    color: var(--ink-soft);
    font-size: 15.5px;
  }

  @media (min-width: 700px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
  }

  .trust-inner {
    max-width: 40rem;
  }

  .trust h2 {
    font-size: clamp(26px, 4vw, 36px);
    margin: 16px 0 28px;
  }

  .trust ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .trust li {
    padding-left: 28px;
    position: relative;
    color: rgba(255, 255, 255, 0.78);
  }

  .trust li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }

  .teasers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  .teasers a {
    display: block;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    background: var(--paper);
    height: 100%;
  }

  .teasers h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .teasers p {
    color: var(--ink-soft);
    font-size: 15px;
    margin-bottom: 12px;
  }

  .teasers span {
    font-weight: 600;
    color: var(--accent);
    font-size: 14.5px;
  }

  @media (min-width: 700px) {
    .teasers {
      grid-template-columns: 1fr 1fr;
    }
  }

  .more {
    display: inline-block;
    margin-top: 28px;
    font-weight: 600;
    text-decoration: none;
  }
</style>
