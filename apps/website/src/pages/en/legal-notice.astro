---
import Base from '../../layouts/Base.astro';

const email = 'raphael@plumservices.co';
const updated = '18 July 2026';
---

<Base
  lang="en"
  routeKey="legal"
  title="Legal notice — Sereno"
  description="Legal notice for the Sereno website and application: publisher, hosting, Stripe (support), contact."
>
  <article class="section">
    <div class="wrap prose">
      <h1>Legal notice</h1>
      <p>Last updated: {updated}</p>
      <p class="notice" lang="fr">
        Version informative — la <a href="/mentions-legales">version française</a> fait foi.
        <span lang="en">(Informative translation — the French version prevails.)</span>
      </p>

      <h2>Publisher</h2>
      <p>
        The Sereno website and application are published on a non-professional
        basis by <strong>Raphaël</strong> (a private individual). Under Article
        6, III-2 of French law no. 2004-575 of 21 June 2004 (LCEN), a
        non-professional publisher may remain anonymous provided their identity
        has been communicated to the hosting provider.
      </p>
      <p>
        Contact: <a href={`mailto:${email}`}>{email}</a>
      </p>
      <p>Publication director: Raphaël.</p>

      <h2>Hosting</h2>
      <p>
        The website and application (static files) are hosted by
        <strong>Cloudflare, Inc.</strong>, 101 Townsend St, San Francisco,
        CA 94107, USA —
        <a href="https://www.cloudflare.com" rel="noopener">cloudflare.com</a>.
      </p>
      <p>
        User account data (optional sync) is hosted by
        <strong>Supabase, Inc.</strong>. The project database is in the
        European Union (AWS eu-west-1, Ireland).
      </p>
      <p>
        Voluntary support payments are processed by
        <strong>Stripe Payments Europe, Ltd.</strong> —
        <a href="https://stripe.com" rel="noopener">stripe.com</a>. Sereno does
        not store card details.
      </p>

      <h2>Intellectual property</h2>
      <p>
        The name “Sereno”, the visual identity, texts and graphic elements of
        this site are the property of their author. Unauthorized reproduction
        is prohibited.
      </p>

      <h2>Reporting content</h2>
      <p>
        For any question or report:
        <a href={`mailto:${email}`}>{email}</a>.
      </p>
    </div>
  </article>
</Base>
