---
import Base from '../layouts/Base.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import { APP_URL, t } from '../i18n/ui';

const tr = t('fr');

const blocks = [
  {
    label: 'Saisie',
    title: 'Deux gestes, et c’est noté',
    body: 'Montant, catégorie, enregistré. Des modèles pour ce qui revient souvent, des virements traités correctement — ni revenu ni dépense.',
    mediaSrc: '/screenshots/transactions.png',
    mediaAlt: 'Écran des transactions Sereno',
  },
  {
    label: 'Budgets',
    title: 'Cadrer sans se punir',
    body: 'Budgets par catégorie ou globaux, projection honnête de fin de période. Un dépassement s’affiche en corail calme : « Dépassé de 50 € — ça arrive. »',
    mediaSrc: '/screenshots/budgets.png',
    mediaAlt: 'Écran des budgets Sereno',
    reverse: true,
  },
  {
    label: 'Statistiques',
    title: 'Voir, d’un regard',
    body: 'Répartition par catégorie, comparaisons de mois, calendrier des jours de dépense. Des faits, jamais de jugement.',
    mediaSrc: '/screenshots/stats.png',
    mediaAlt: 'Écran des statistiques Sereno',
  },
  {
    label: 'Mode invité',
    title: 'Complet, sans compte',
    body: 'Transactions, budgets, stats, calendrier — tout fonctionne en local sur ton appareil. Aucun quota, aucune limite artificielle.',
    mediaSrc: '/screenshots/guest.png',
    mediaAlt: 'Mode invité Sereno',
    reverse: true,
  },
  {
    label: 'Sync',
    title: 'Compte optionnel, gratuit',
    body: 'Quand tu veux synchroniser plusieurs appareils : comptes multiples, catégories perso, récurrences côté serveur. Tes données locales migrent sans perte.',
    mediaSrc: '/screenshots/dashboard.png',
    mediaAlt: 'Tableau de bord Sereno synchronisé',
  },
];
---

<Base
  lang="fr"
  routeKey="features"
  title="Fonctionnalités — Sereno"
  description="Saisie en deux gestes, budgets calmes, statistiques posées, mode hors-ligne : tout ce que fait Sereno, sans jamais te presser."
>
  <section class="hero-head section-soft">
    <div class="wrap">
      <div class="section-head">
        <span class="lbl">Fonctionnalités</span>
        <h1>Tout ce qu’il faut pour y voir clair.</h1>
        <p>
          Sereno fait exprès d’en faire moins : pas de connexion bancaire, pas
          de notifications pressantes, pas d’IA. Ce qui reste est soigné —
          et gratuit pour toujours.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {
        blocks.map((block) => (
          <FeatureBlock
            label={block.label}
            title={block.title}
            body={block.body}
            mediaSrc={block.mediaSrc}
            mediaAlt={block.mediaAlt}
            reverse={block.reverse}
          />
        ))
      }

      <div class="cta-row">
        <div class="cta-band cta-band-coral">
          <h2>Essaye sans rien configurer.</h2>
          <p>L’app s’ouvre en mode invité. Tu notes, tu vois, c’est tout.</p>
          <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>{tr('cta.openApp')}</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-head {
    padding: 64px 0 24px;
  }

  h1 {
    font-size: clamp(30px, 5vw, 42px);
  }

  .cta-row {
    margin-top: 40px;
  }
</style>
