---
import Base from '../layouts/Base.astro';
import PhoneMock from '../components/PhoneMock.astro';
import { APP_URL, href, t } from '../i18n/ui';
import { getCollection } from 'astro:content';

const tr = t('fr');

const posts = (await getCollection('blog', ({ data }) => data.lang === 'fr'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const pillars = [
  {
    title: 'Local d’abord',
    body: 'Tes données restent sur ton appareil. Un compte n’est utile que si tu veux synchroniser plusieurs appareils — et il est gratuit.',
    icon: '/illustrations/local-first.svg',
  },
  {
    title: 'Manuel, exprès',
    body: 'Pas de connexion bancaire. Noter une dépense toi-même prend cinq secondes — c’est précisément ce geste qui te remet aux commandes.',
    icon: '/illustrations/hero-clarity.svg',
  },
  {
    title: 'Jamais d’alarme',
    body: 'Un budget dépassé n’est pas une faute. Sereno l’énonce calmement, en corail — et t’aide à ajuster le mois suivant.',
    icon: '/illustrations/support-coffee.svg',
  },
];
---

<Base
  lang="fr"
  routeKey="home"
  title="Sereno — vois clair dans ton argent, sans anxiété"
  description={tr('site.description')}
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="lbl">Budget personnel · gratuit</span>
        <h1>Vois clair dans ton argent, sans anxiété.</h1>
        <p>
          Tu notes tes dépenses à la main, en deux gestes. Sereno te montre où
          va ton argent — posément, sans culpabilisation. Gratuit pour toujours,
          sans compte, directement sur ton appareil.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>
            {tr('cta.openApp')}
          </a>
          <a class="btn btn-ghost" href={href('fr', 'method')}>Découvrir la méthode</a>
        </div>
        <p class="hero-note">Sans inscription · Sans connexion bancaire · Sans pub</p>
      </div>
      <div class="hero-visual">
        <img class="hero-illo" src="/illustrations/hero-clarity.svg" alt="" width="200" height="160" />
        <PhoneMock src="/screenshots/dashboard.png" alt="Tableau de bord Sereno" width={250} />
      </div>
    </div>
  </section>

  <section class="section section-surface" aria-label="Les trois principes de Sereno">
    <div class="wrap pillars">
      {
        pillars.map((pillar) => (
          <article class="pillar">
            <img src={pillar.icon} alt="" width="48" height="48" />
            <h2>{pillar.title}</h2>
            <p>{pillar.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section-dark trust">
    <div class="wrap trust-inner">
      <span class="lbl">Confiance</span>
      <h2>Gratuit pour toujours. Tes données restent les tiennes.</h2>
      <ul>
        <li>Mode invité complet, sans quota ni limite artificielle</li>
        <li>Compte optionnel uniquement pour synchroniser tes appareils</li>
        <li>Pas d’IA, pas de scan de reçus, pas de revente de données</li>
        <li>Soutien volontaire possible — jamais obligatoire</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="lbl">Blog</span>
        <h2>Des guides calmes pour ton argent.</h2>
      </div>
      <ul class="teasers">
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id.replace(/^fr\//, '')}`}>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <span>{tr('blog.readMore')} →</span>
              </a>
            </li>
          ))
        }
      </ul>
      <a class="more" href={href('fr', 'blog')}>Tout le blog →</a>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <div class="cta-band cta-band-coral">
        <h2>Commence maintenant. Littéralement maintenant.</h2>
        <p>Pas de compte à créer. L’app s’ouvre, tu notes ta première dépense, c’est parti.</p>
        <a class="btn btn-primary" href={APP_URL} aria-label={tr('cta.openApp.aria')}>{tr('cta.openApp')}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 72px 0 80px;
    background: var(--paper-soft);
  }

  .hero-grid {
    display: grid;
    gap: 48px;
    align-items: center;
    grid-template-columns: 1fr;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    max-width: 34rem;
  }

  h1 {
    font-size: clamp(34px, 5.4vw, 52px);
  }

  .hero-copy > p {
    color: var(--ink-soft);
    font-size: 18px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-note {
    font-size: 13.5px;
    color: var(--ink-faint);
  }

  .hero-visual {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 16px;
    position: relative;
  }

  .hero-illo {
    display: none;
    width: 140px;
    height: auto;
    opacity: 0.9;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.15fr 0.85fr;
    }

    .hero-illo {
      display: block;
      position: absolute;
      left: 0;
      top: 12%;
    }

    .hero-visual {
      justify-content: flex-end;
      min-height: 420px;
    }
  }

  .pillars {
    display: grid;
    gap: 36px;
    grid-template-columns: 1fr;
  }

  .pillar img {
    margin-bottom: 12px;
  }

  .pillar h2 {
    font-size: 21px;
    margin-bottom: 10px;
  }

  .pillar p {
    color: var(--ink-soft);
    font-size: 15.5px;
  }

  @media (min-width: 700px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
  }

  .trust-inner {
    max-width: 40rem;
  }

  .trust h2 {
    font-size: clamp(26px, 4vw, 36px);
    margin: 16px 0 28px;
  }

  .trust ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .trust li {
    padding-left: 28px;
    position: relative;
    color: rgba(255, 255, 255, 0.78);
  }

  .trust li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }

  .teasers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }

  .teasers a {
    display: block;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    background: var(--paper);
    height: 100%;
  }

  .teasers h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .teasers p {
    color: var(--ink-soft);
    font-size: 15px;
    margin-bottom: 12px;
  }

  .teasers span {
    font-weight: 600;
    color: var(--accent);
    font-size: 14.5px;
  }

  @media (min-width: 700px) {
    .teasers {
      grid-template-columns: 1fr 1fr;
    }
  }

  .more {
    display: inline-block;
    margin-top: 28px;
    font-weight: 600;
    text-decoration: none;
  }
</style>
