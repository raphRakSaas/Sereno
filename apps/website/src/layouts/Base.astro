---
import '@fontsource-variable/sora';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@sereno/brand/tokens.css';
import '../styles/site.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { href, routeMap, type Lang, type RouteKey } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Route logique — sert au hreflang et au sélecteur de langue. */
  routeKey?: RouteKey;
  /** Alternates explicites quand les slugs ne se déduisent pas (articles de blog). */
  alternates?: Partial<Record<Lang, string>>;
}

const { lang, title, description, routeKey, alternates } = Astro.props;

const site = Astro.site!;
const canonical = new URL(Astro.url.pathname, site);
const alternateFr = alternates?.fr ?? (routeKey ? href('fr', routeKey) : null);
const alternateEn = alternates?.en ?? (routeKey ? href('en', routeKey) : null);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateFr && <link rel="alternate" hreflang="fr" href={new URL(alternateFr, site)} />}
    {alternateEn && <link rel="alternate" hreflang="en" href={new URL(alternateEn, site)} />}
    {alternateFr && <link rel="alternate" hreflang="x-default" href={new URL(alternateFr, site)} />}
    <meta name="theme-color" content="#FF4D6D" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <slot name="head" />
  </head>
  <body>
    <Header
      lang={lang}
      switchHref={lang === 'fr' ? (alternateEn ?? routeMap.home.en) : (alternateFr ?? routeMap.home.fr)}
    />
    <main id="contenu">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      // Révélation douce au scroll. Sans JS ou avec prefers-reduced-motion,
      // rien n'est masqué : les classes .anim ne sont posées qu'ici.
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion && 'IntersectionObserver' in window) {
        const revealSelectors = [
          '.hero-copy',
          '.hero-visual',
          '.section-head',
          '.pillar',
          '.feature-block',
          '.trust-inner',
          '.teasers > li',
          '.posts > li',
          '.tier',
          '.channel',
          '.why',
          '.cta-band',
          '.about-grid > *',
          '.free-grid > *',
          '.faq-acc .item',
          'main .prose',
          '.notfound',
        ].join(',');

        const revealTargets = Array.from(document.querySelectorAll<HTMLElement>(revealSelectors));
        const siblingCountByParent = new Map<HTMLElement | null, number>();

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('anim-in');
              observer.unobserve(entry.target);
            }
          },
          { rootMargin: '0px 0px -60px 0px' },
        );

        for (const target of revealTargets) {
          const parent = target.parentElement;
          const siblingIndex = siblingCountByParent.get(parent) ?? 0;
          siblingCountByParent.set(parent, siblingIndex + 1);

          target.style.setProperty('--anim-i', String(siblingIndex));
          target.classList.add('anim');
          // Une fois révélé, on rend la main aux styles normaux (survols, etc.).
          // transitionend bulle depuis les enfants : on ne réagit qu'à la cible.
          const releaseAnimationState = (event: TransitionEvent) => {
            if (event.target !== target) return;
            target.classList.remove('anim', 'anim-in');
            target.style.removeProperty('--anim-i');
            target.removeEventListener('transitionend', releaseAnimationState);
          };
          target.addEventListener('transitionend', releaseAnimationState);
          observer.observe(target);
        }
      }
    </script>
  </body>
</html>
